{
  "version": 2,
  "public": false,
  "buildCommand": "npm run build:prod",
  "outputDirectory": "dist/lost-yeti",
  "framework": "angular",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/naar2noor2(.*)",
      "destination": "https://naar-noor.vercel.app$1",
      "permanent": true
    },
    {
      "source": "/naar2noor(.*)",
      "destination": "https://naar-noor.vercel.app$1",
      "permanent": true
    },
    {
      "source": "/naar222noor(.*)",
      "destination": "https://naar-noor.vercel.app$1",
      "permanent": true
    }
  ]
}
